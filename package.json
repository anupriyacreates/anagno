{
  "name": "research-diver",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI-powered problem discovery & systems analysis for designers and researchers — chat + infinite canvas.",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "start": "tsx server/index.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.68.0",
    "@xyflow/react": "^12.8.6",
    "cors": "^2.8.5",
    "docx": "^9.7.1",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsx": "^4.20.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  }
}
